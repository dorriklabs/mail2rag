# ============================================================================
# MAIL2RAG3 - Fichier de Configuration Principal
# ============================================================================
# Ce fichier centralise la configuration des 3 conteneurs de l'application :
# 1. mail2rag (Le moteur principal de traitement des emails)
# 2. rag_proxy (La base de données vectorielle et l'IA)
# 3. streamlit_admin (L'interface web d'administration)
#
# LÉGENDE :
# (OBLIGATOIRE) : Doit absolument être configuré pour que le système démarre
# (FACULTATIF) : Peut être laissé vide ou désactivé (false)
# ============================================================================

# ============================================================================
# 1. CONTENEUR : MAIL2RAG (MOTEUR PRINCIPAL)
# ============================================================================

# --- 1.1 PROTOCOLES MESSAGERIE ---
# (OBLIGATOIRE) Protocole utilisé : "imap" ou "msgraph"
MAIL_PROVIDER=imap

# Accès IMAP/SMTP classiques (Obligatoires si MAIL_PROVIDER=imap)
IMAP_SERVER=imap.example.com
IMAP_PORT=993
IMAP_USER=rag@example.com
IMAP_PASSWORD=CHANGE_ME
IMAP_TIMEOUT=30

SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=rag@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_TIMEOUT=30

# Accès Microsoft Graph API (Obligatoires si MAIL_PROVIDER=msgraph)
MS_TENANT_ID=votre_tenant_id
MS_CLIENT_ID=votre_client_id
MS_CLIENT_SECRET=votre_client_secret

# --- 1.2 COMPORTEMENT DE L'AGENT ---
# (OBLIGATOIRE) Dossier IMAP à surveiller et fréquence (en secondes)
IMAP_FOLDER=INBOX
IMAP_SEARCH_CRITERIA=UNSEEN
IMAP_POLL_INTERVAL=60

# (OBLIGATOIRE) Workspace utilisé par défaut si le routing échoue
DEFAULT_WORKSPACE=default-workspace
DEFAULT_SUBJECT=No_Subject

# (FACULTATIF) Strict routing: Empêche les utilisateurs d'utiliser la balise "Workspace:"
ENFORCE_STRICT_ROUTING=false

# --- 1.3 NOTIFICATIONS ---
# (FACULTATIF) Notifications sur les messageries d'entreprise
TEAMS_WEBHOOK_URL=https://dsiatlantic.webhook.office.com/webhookb2/...
SLACK_WEBHOOK_URL=
GOOGLE_CHAT_WEBHOOK_URL=

# --- 1.4 FONCTIONNALITÉS MÉTIER ---
# (FACULTATIF) Dispatch IA : Transfert SMTP automatique selon le sujet/contenu
ENABLE_SEMANTIC_DISPATCH=false
SEMANTIC_DISPATCH_MAPPING=Urbanisme:urba@mairie.fr,Etat-Civil:etat-civil@mairie.fr,Police:police@mairie.fr

# (FACULTATIF) Smart Filter : Ignore les emails sans valeur ajoutée (spams, "merci")
ENABLE_SMART_INGESTION_FILTER=false

# (FACULTATIF) Résumés d'ingestion par IA
ENABLE_EMAIL_SUMMARY=false
SUMMARY_MAX_SENTENCES=3
SUMMARY_MAX_TOKENS=150

# (FACULTATIF) Support QA : Génération de brouillons (Draft) IA dans la boite mail
IMAP_DRAFTS_FOLDER=
IMAP_PROCESSED_FOLDER=En cours
DRAFT_TIMEOUT_HOURS=24
SUPPORT_QA_TEMPERATURE=0.1
SUPPORT_QA_MAX_TOKENS=1200


# ============================================================================
# 2. CONTENEUR : RAG_PROXY (INTELLIGENCE & BASE DE DONNÉES)
# ============================================================================

# --- 2.1 CONFIGURATION DES MODÈLES LLM ---
# (OBLIGATOIRE) Fournisseur principal d'IA (ex: lmstudio, openai, mistral, groq...)
LLM_PROVIDER=lmstudio

# Paramètres locaux (Si LLM_PROVIDER=lmstudio ou ollama)
LM_STUDIO_URL=http://host.docker.internal:1234
OLLAMA_BASE_URL=http://localhost:11434

# Clés d'API (Obligatoires uniquement si LLM_PROVIDER = un acteur Cloud)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# (FACULTATIF) Forcer un modèle spécifique (Laissez vide pour utiliser le défaut)
LLM_CHAT_MODEL_LITELLM=
LLM_EMBED_MODEL_LITELLM=
LLM_FALLBACK_MODELS=

# (OBLIGATOIRE) Comportement de génération
LLM_CHAT_MODEL=qwen/qwen3-vl-8b
LLM_CHAT_TIMEOUT=120
DEFAULT_LLM_TEMPERATURE=0.7
LLM_MAX_CONTEXT_TOKENS=6000
LLM_CHAT_SYSTEM_PROMPT=Tu es un assistant IA serviable. Réponds de manière concise et précise en te basant uniquement sur le contexte fourni.
DEFAULT_REFUSAL_RESPONSE=Je ne trouve pas d information pertinente dans vos documents pour répondre à cette question.

# --- 2.2 BASE VECTORIELLE (QDRANT) ---
# (OBLIGATOIRE) 
VECTOR_DB_HOST=qdrant
VECTOR_DB_PORT=6333
VECTOR_DB_COLLECTION=documents
MULTI_COLLECTION_MODE=true

# --- 2.3 RECHERCHE HYBRIDE & DÉCOUPAGE ---
# (OBLIGATOIRE) Modèle de transformation de texte en vecteurs
EMBEDDING_MODEL_PREF=text-embedding-bge-m3
EMBED_MODEL=text-embedding-bge-m3

# (OBLIGATOIRE) Paramètres de découpage des documents indexés
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHUNKING_STRATEGY=recursive

# (FACULTATIF) Algorithme de tri intelligent (Reranker local)
USE_LOCAL_RERANKER=true
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
AUTO_REBUILD_BM25=true

# --- 2.4 SÉCURITÉ RAG PROXY ---
# (FACULTATIF) Protéger l'API RAG avec un jeton
API_KEY_ENABLED=false
RAG_PROXY_API_KEY=


# ============================================================================
# 3. CONTENEUR : TIKA & VISION AI (EXTRACTION DOCUMENTAIRE)
# ============================================================================

# (OBLIGATOIRE) Extraction de texte classique (Tika)
TIKA_SERVER_URL=http://tika:9998
TIKA_TIMEOUT=180
TIKA_ENABLE=true
TIKA_FALLBACK_TO_VISION=true

# (FACULTATIF) Extraction visuelle (Images et PDF complexes via LLM Vision)
VISION_ENABLE_IMAGES=true
VISION_ENABLE_PDF=true
VISION_TEMPERATURE=0.0
VISION_MAX_TOKENS=1500
VISION_TIMEOUT=90
LLM_VISION_MODEL=

# Filtres de fichiers
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.txt,.md,.csv,.xlsx,.xls,.pptx,.ppt,.html,.xml,.json,.jpg,.jpeg,.png,.bmp,.webp,.odt,.ods,.odp,.rtf,.epub,.eml,.msg,.gif,.tiff,.tif,.svg
BLOCKED_EXTENSIONS=.exe,.bin,.bat,.sh,.zip,.rar,.7z,.tar,.gz,.iso,.dll
MAX_FILENAME_LENGTH=100
MIN_IMAGE_SIZE_KB=5
OCR_DPI=300


# ============================================================================
# 4. CONTENEUR : STREAMLIT_ADMIN (INTERFACE WEB)
# ============================================================================

# (OBLIGATOIRE) Identifiants pour se connecter au tableau de bord
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_securely

# (OBLIGATOIRE) Clé secrète de chiffrement des cookies web (A CHANGER !)
COOKIE_KEY=some_random_secret_string


# ============================================================================
# 5. GLOBAL, CHEMINS & MAINTENANCE
# ============================================================================

# (FACULTATIF) SAAS Ready : Identification du client
TENANT_ID=
TENANT_NAME=

# (OBLIGATOIRE) Chemins système
STATE_PATH=/var/lib/mail2rag/state.json
ARCHIVE_PATH=/var/lib/mail2rag/mail2rag_archive
ROUTING_PATH=/etc/mail2rag/routing.json
PROMPTS_DIR=/etc/mail2rag/prompts

# Urls internes
RAG_PROXY_URL=http://rag_proxy:8000
USE_RAG_PROXY_FOR_SEARCH=true
ARCHIVE_BASE_URL=http://localhost:8080

# (FACULTATIF) Logs et Historique
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_TRUNCATE_HEAD=5
LOG_TRUNCATE_TAIL=3
LOG_MAX_LINE_LENGTH=500
SAVE_CHAT_HISTORY=true

# (FACULTATIF) Maintenance et Concurrence
CLEANUP_ARCHIVE_BEFORE_SYNC=false
SYNC_ON_START=true
WORKER_COUNT=1
WORKER_QUEUE_SIZE=50
