# ============================================================================
# MAIL2RAG3 - Fichier de Configuration Principal
# ============================================================================
# Ce fichier sert de modèle.
# Copiez-le en .env puis adaptez les valeurs sensibles.
#
# IMPORTANT :
# - Ne versionnez jamais le vrai fichier .env.
# - Ne mettez jamais de vrai mot de passe, clé API ou webhook dans .env.example.
# ============================================================================


# ============================================================================
# 1. CONTENEUR : MAIL2RAG - MOTEUR PRINCIPAL
# ============================================================================

# --- 1.1 PROTOCOLES MESSAGERIE ---

MAIL_PROVIDER=imap

IMAP_SERVER=imap.example.com
IMAP_PORT=993
IMAP_USER=rag@example.com
IMAP_PASSWORD=CHANGE_ME
IMAP_TIMEOUT=30

SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=rag@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_TIMEOUT=30

MS_TENANT_ID=CHANGE_ME
MS_CLIENT_ID=CHANGE_ME
MS_CLIENT_SECRET=CHANGE_ME


# --- 1.2 COMPORTEMENT DE L'AGENT ---

IMAP_FOLDER=INBOX
IMAP_SEARCH_CRITERIA=UNSEEN
IMAP_POLL_INTERVAL=60

DEFAULT_WORKSPACE=default-workspace
DEFAULT_SUBJECT=No_Subject

ENFORCE_STRICT_ROUTING=false

ALLOWED_DOMAINS=


# --- 1.3 NOTIFICATIONS ---

TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
GOOGLE_CHAT_WEBHOOK_URL=


# --- 1.4 FONCTIONNALITÉS MÉTIER ---

ENABLE_SEMANTIC_DISPATCH=false
SEMANTIC_DISPATCH_MAPPING=Urbanisme:urba@example.com,Etat-Civil:etatcivil@example.com,Police:police@example.com

ENABLE_SMART_INGESTION_FILTER=false
METADATA_EXTRACTION_MAPPING=FACTURE:montant,fournisseur|URBANISME:commune,zone,parcelle

ENABLE_EMAIL_SUMMARY=false
SUMMARY_MAX_SENTENCES=3
SUMMARY_MAX_TOKENS=150

IMAP_DRAFTS_FOLDER=
IMAP_PROCESSED_FOLDER=En cours
DRAFT_TIMEOUT_HOURS=24
SUPPORT_QA_TEMPERATURE=0.1
SUPPORT_QA_MAX_TOKENS=1200

# --- 1.5 BCC INGESTION (Alimentation RAG par les agents) ---
ENABLE_BCC_INGESTION=false
BCC_ALLOWED_DOMAINS=example.com,mairie.fr
INGESTION_EMAIL_ADDRESS=rag@example.com
BCC_DEDUPLICATION_THRESHOLD=0.95


# ============================================================================
# 2. CONTENEUR : RAG_PROXY - IA, RAG, QDRANT, BM25
# ============================================================================

# --- 2.1 CONFIGURATION DES MODÈLES LLM ---

LLM_PROVIDER=lmstudio

LM_STUDIO_URL=http://host.docker.internal:1234
OLLAMA_BASE_URL=http://host.docker.internal:11434

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

LLM_CHAT_MODEL_LITELLM=
LLM_EMBED_MODEL_LITELLM=
LLM_FALLBACK_MODELS=

LLM_CHAT_MODEL=qwen/qwen3-vl-8b
LLM_CHAT_TIMEOUT=120
DEFAULT_LLM_TEMPERATURE=0.7
LLM_MAX_CONTEXT_TOKENS=6000

LLM_CHAT_SYSTEM_PROMPT=Tu es un assistant IA d'entreprise expert. Réponds avec précision en te basant exclusivement sur le contexte fourni. Si l'information n'est pas présente ou que les documents ne contiennent pas de réponse, tu DOIS le dire clairement et explicitement (ex: "Il n'y a pas d'informations à ce sujet dans les documents"). Ne tente jamais de deviner ou d'halluciner une réponse.
DEFAULT_REFUSAL_RESPONSE=Il n'y a pas d'informations à ce sujet dans les documents fournis.


# --- 2.2 BASE VECTORIELLE - QDRANT ---

VECTOR_DB_HOST=qdrant
VECTOR_DB_PORT=6333

VECTOR_DB_COLLECTION=documents
MULTI_COLLECTION_MODE=true


# --- 2.3 RECHERCHE HYBRIDE & DÉCOUPAGE ---

EMBEDDING_MODEL_PREF=text-embedding-bge-m3
EMBED_MODEL=text-embedding-bge-m3

CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHUNKING_STRATEGY=recursive

USE_BM25=true
BM25_INDEX=/bm25/bm25.pkl
AUTO_REBUILD_BM25=true

USE_LOCAL_RERANKER=true
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2


# --- 2.4 SÉCURITÉ RAG PROXY ---

API_KEY_ENABLED=false
RAG_PROXY_API_KEY=


# ============================================================================
# 3. CONTENEUR : TIKA & VISION AI - EXTRACTION DOCUMENTAIRE
# ============================================================================

TIKA_SERVER_URL=http://tika:9998
TIKA_TIMEOUT=180
TIKA_ENABLE=true
TIKA_FALLBACK_TO_VISION=true

VISION_ENABLE_IMAGES=true
VISION_ENABLE_PDF=true
VISION_PDF_MODE=low_quality_pages
VISION_PDF_MAX_PAGES=5
VISION_PDF_DPI=150
VISION_FORCE_ON_TABLES=false
VISION_MAX_CONCURRENT_CALLS=1
VISION_TEMPERATURE=0.0
VISION_MAX_TOKENS=1500
VISION_TIMEOUT=90
LLM_VISION_MODEL=

ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.txt,.md,.csv,.xlsx,.xls,.pptx,.ppt,.html,.xml,.json,.jpg,.jpeg,.png,.bmp,.webp,.odt,.ods,.odp,.rtf,.epub,.eml,.msg,.gif,.tiff,.tif,.svg
BLOCKED_EXTENSIONS=.exe,.bin,.bat,.sh,.zip,.rar,.7z,.tar,.gz,.iso,.dll
MAX_FILENAME_LENGTH=100
MIN_IMAGE_SIZE_KB=5
OCR_DPI=300


# ============================================================================
# 4. CONTENEUR : STREAMLIT_ADMIN - INTERFACE WEB
# ============================================================================

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_securely

COOKIE_KEY=some_random_secret_string


# ============================================================================
# 5. GLOBAL, CHEMINS & MAINTENANCE
# ============================================================================

TENANT_ID=
TENANT_NAME=

STATE_PATH=/var/lib/mail2rag/state.json
ARCHIVE_PATH=/var/lib/mail2rag/mail2rag_archive
ROUTING_PATH=/etc/mail2rag/routing.json
PROMPTS_DIR=/etc/mail2rag/prompts

RAG_PROXY_URL=http://rag_proxy:8000
USE_RAG_PROXY_FOR_SEARCH=true

ARCHIVE_BASE_URL=http://localhost:9102

LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_TRUNCATE_HEAD=5
LOG_TRUNCATE_TAIL=3
LOG_MAX_LINE_LENGTH=500
SAVE_CHAT_HISTORY=true

CLEANUP_ARCHIVE_BEFORE_SYNC=false
SYNC_ON_START=false
WORKER_COUNT=1
WORKER_QUEUE_SIZE=50
INGESTION_MAX_WORKERS=2
INGESTION_QUEUE_MAX_SIZE=20
INGESTION_ASYNC=true
INGESTION_CACHE=true
STRUCTURED_INGESTION_ENABLED=false